<IfModule mod_rewrite.c>
  RewriteEngine On
  # SPA fallback: serve index.html for all non-file routes
  RewriteBase /preview-noworries-2026/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Powered-By "OneClickFix"

  # Cache control: CDN caches for 7 days, browser re-validates
  Header set Cache-Control "public, s-maxage=604800, max-age=0"
  
  # Hashed assets (JS/CSS) can be cached aggressively by the browser
  <If "%{REQUEST_URI} =~ m#^/.*/assets/.*$#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>

  # Images: cache for 30 days in browser
  <If "%{REQUEST_URI} =~ m#^/.*/images/.*$#">
    Header set Cache-Control "public, max-age=2592000"
  </If>
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
