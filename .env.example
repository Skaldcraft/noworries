# Copia este archivo como .env y rellena los valores reales.
# El archivo .env NUNCA debe subirse al repositorio (está en .gitignore).

# Credenciales de Amazon PA API 5.0
# Obtenlas en: https://affiliate-program.amazon.es/help/topic/t405
AMAZON_ACCESS_KEY=TU_AWS_ACCESS_KEY_ID
AMAZON_SECRET_KEY=TU_AWS_SECRET_ACCESS_KEY

